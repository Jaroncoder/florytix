<svg width="400" height="400" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="400" height="400" fill="#E0B0FF"/>
  
  <!-- Gradient Overlay -->
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FF1493;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#9B59B6;stop-opacity:0.3" />
    </linearGradient>
  </defs>
  <rect width="400" height="400" fill="url(#grad1)"/>
  
  <!-- Flower Icon -->
  <g transform="translate(200, 200)">
    <!-- Petals -->
    <ellipse cx="0" cy="-40" rx="25" ry="35" fill="#FF69B4" opacity="0.8"/>
    <ellipse cx="38" cy="-12" rx="25" ry="35" fill="#FF69B4" opacity="0.8" transform="rotate(72 200 200)"/>
    <ellipse cx="23" cy="32" rx="25" ry="35" fill="#FF69B4" opacity="0.8" transform="rotate(144 200 200)"/>
    <ellipse cx="-23" cy="32" rx="25" ry="35" fill="#FF69B4" opacity="0.8" transform="rotate(216 200 200)"/>
    <ellipse cx="-38" cy="-12" rx="25" ry="35" fill="#FF69B4" opacity="0.8" transform="rotate(288 200 200)"/>
    
    <!-- Center -->
    <circle cx="0" cy="0" r="20" fill="#FFD700"/>
    <circle cx="0" cy="0" r="12" fill="#FF1493" opacity="0.5"/>
  </g>
  
  <!-- Text -->
  <text x="200" y="330" font-family="Arial, sans-serif" font-size="24" fill="#FFFFFF" text-anchor="middle" font-weight="bold">
    Florytix
  </text>
  <text x="200" y="360" font-family="Arial, sans-serif" font-size="16" fill="#FFFFFF" text-anchor="middle" opacity="0.9">
    Add your image here
  </text>
</svg>
