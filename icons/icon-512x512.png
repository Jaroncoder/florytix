<svg width="512" height="512" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="512" height="512" fill="#FF1493" rx="80"/>
  
  <!-- Gradient Overlay -->
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FF69B4;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#C71585;stop-opacity:0.3" />
    </linearGradient>
    <filter id="shadow">
      <feDropShadow dx="0" dy="4" stdDeviation="8" flood-color="#000000" flood-opacity="0.3"/>
    </filter>
  </defs>
  <rect width="512" height="512" fill="url(#grad)" rx="80"/>
  
  <!-- Main Flower -->
  <g transform="translate(256, 256)" filter="url(#shadow)">
    <!-- Large Petals -->
    <ellipse cx="0" cy="-80" rx="50" ry="70" fill="#FFFFFF" opacity="0.95"/>
    <ellipse cx="75" cy="-25" rx="50" ry="70" fill="#FFFFFF" opacity="0.95" transform="rotate(72 256 256)"/>
    <ellipse cx="46" cy="64" rx="50" ry="70" fill="#FFFFFF" opacity="0.95" transform="rotate(144 256 256)"/>
    <ellipse cx="-46" cy="64" rx="50" ry="70" fill="#FFFFFF" opacity="0.95" transform="rotate(216 256 256)"/>
    <ellipse cx="-75" cy="-25" rx="50" ry="70" fill="#FFFFFF" opacity="0.95" transform="rotate(288 256 256)"/>
    
    <!-- Center Circle -->
    <circle cx="0" cy="0" r="40" fill="#FFD700"/>
    <circle cx="0" cy="0" r="30" fill="#FFA500" opacity="0.8"/>
    <circle cx="0" cy="0" r="20" fill="#FF8C00" opacity="0.6"/>
  </g>
  
  <!-- Brand Text -->
  <text x="256" y="440" font-family="Arial, sans-serif" font-size="56" fill="#FFFFFF" text-anchor="middle" font-weight="bold">
    Florytix
  </text>
</svg>
